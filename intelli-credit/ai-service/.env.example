ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_MODEL_PATH=/absolute/path/to/deepseek-vl2-tiny
# Host path to model weights folder — mounted read-only into container at /models/deepseek-vl2-tiny
# Expected: a HuggingFace model directory with config.json, tokenizer files, and .safetensors shards.
# Download with: huggingface-cli download deepseek-ai/deepseek-vl2-tiny --local-dir /path/to/deepseek-vl2-tiny
TAVILY_API_KEY=
SERPER_API_KEY=your_serper_key_here
# When Serper's 2500 free credits are exhausted, the system automatically
# falls back to DuckDuckGo. No action required — fallback is automatic.
JINA_API_KEY=jina_...
# Jina model: jina-embeddings-v2-base-en (768-dim)
SUPABASE_URL=
SUPABASE_ANON_KEY=
GO_SERVICE_URL=http://localhost:8001
PYTHON_SERVICE_URL=http://localhost:8002

# Qdrant (RAG vector store)
QDRANT_HOST=qdrant
# For local dev outside Docker, use: localhost
QDRANT_PORT=6333
QDRANT_URL=http://localhost:6333
# Qdrant Dashboard: http://localhost:6333/dashboard (inspect collections, view stored vectors)
# Reset vectors: docker volume rm intelli-credit_qdrant_data

# Neo4j (Entity Graph)
NEO4J_URI=bolt://neo4j:7687
# For local dev outside Docker, use: bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=intelli_credit_neo4j
# Neo4j Browser: http://localhost:7474 (login: neo4j / intelli_credit_neo4j)
# Bolt port 7687 — do NOT expose publicly in production
# Reset graph: docker volume rm intelli-credit_neo4j_data

# ML Core Models Directory
MODEL_DIR=/models/ml_artifacts

# Databricks SQL Warehouse (ML Features)
DATABRICKS_HOST=https://adb-xxxx.azuredatabricks.net
DATABRICKS_TOKEN=dapi...
DATABRICKS_SQL_WAREHOUSE_ID=xxxx
